.ui.button {
  &.clear-filters-button {
    color: black;
    margin-bottom: 5px;
  }

  &.facets-sidebar-open-button {
    position: relative;
    padding: 0.7rem;
    .icon {
      margin: 0 !important;
    }
  }

  &#scroll-to-top-button {
    position: fixed;
    bottom: 12rem;
    right: 2rem;
    z-index: 1000;
    background-color: @primaryColor;
    color: @white;
    border: none;
    padding: 0.75rem;

    .icon {
      color: @white;
    }
  }
}
